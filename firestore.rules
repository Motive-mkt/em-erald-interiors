rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrappedOwner() {
      return isSignedIn() && 
             request.auth.token.email == "jessescaledyou@gmail.com";
    }

    // Check if the user is registered as an owner OR is the bootstrapped owner
    function isOwner() {
      return isSignedIn() && (
        isBootstrappedOwner() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner")
      );
    }

    // Check if the user is a registered approved user, registered owner, or the bootstrapped owner
    function isApprovedUser() {
      return isSignedIn() && (
        isBootstrappedOwner() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner" || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true
        ))
      );
    }

    // --- ENTITY SCHEMA VALIDATIONS (COMPILE-SAFE) ---

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             (data.role == "owner" || data.role == "employee") &&
             data.approved is bool &&
             (data.get('displayName', null) == null || (data.displayName is string && data.displayName.size() <= 128)) &&
             (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    function isValidMessage(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.phone is string && data.phone.size() <= 32 &&
             data.email is string && data.email.size() <= 128 &&
             data['service'] is string && data['service'].size() <= 128 &&
             data['message'] is string && data['message'].size() <= 5000 &&
             (data.status == "unread" || data.status == "contacted" || data.status == "archived") &&
             data.createdAt == request.time;
    }

    function isValidService(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 128 &&
             data.desc is string && data.desc.size() <= 1024 &&
             data.icon is string && data.icon.size() <= 64 &&
             data.order is int;
    }

    function isValidGalleryItem(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.url is string && data.url.size() <= 3145728 &&
             data.tag is string && data.tag.size() <= 64 &&
             data.title is string && data.title.size() <= 128 &&
             data.span is string && data.span.size() <= 64 &&
             (data.get('order', null) == null || data.order is int);
    }

    function isValidSiteConfig(data) {
      return data.heroTitleLine1 is string && data.heroTitleLine1.size() <= 256 &&
             data.heroTitleLine2 is string && data.heroTitleLine2.size() <= 256 &&
             data.heroTitleItalic is string && data.heroTitleItalic.size() <= 256 &&
             data.heroParagraph is string && data.heroParagraph.size() <= 2048 &&
             data.contactPhone is string && data.contactPhone.size() <= 32 &&
             data.contactInstagram is string && data.contactInstagram.size() <= 128 &&
             data.contactOpeningHours is string && data.contactOpeningHours.size() <= 256 &&
             data.whatsappNumber is string && data.whatsappNumber.size() <= 32 &&
             (data.get('logoUrl', null) == null || (data.logoUrl is string && data.logoUrl.size() <= 3145728)) &&
             (data.get('splashUrl1', null) == null || (data.splashUrl1 is string && data.splashUrl1.size() <= 3145728)) &&
             (data.get('splashUrl2', null) == null || (data.splashUrl2 is string && data.splashUrl2.size() <= 3145728)) &&
             (data.get('splashUrl3', null) == null || (data.splashUrl3 is string && data.splashUrl3.size() <= 3145728)) &&
             (data.get('splashUrl4', null) == null || (data.splashUrl4 is string && data.splashUrl4.size() <= 3145728));
    }

    // --- COLLECTION RULES MATCHERS ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isApprovedUser());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isOwner() && isValidUser(request.resource.data);
      allow delete: if isOwner() && userId != request.auth.uid;
    }

    // 2. Messages Collection
    match /messages/{messageId} {
      allow get, list: if isApprovedUser();
      allow create: if isValidMessage(request.resource.data);
      allow update: if isApprovedUser();
      allow delete: if isOwner();
    }

    // 3. Services Collection
    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isApprovedUser() && isValidService(request.resource.data);
      allow delete: if isApprovedUser();
    }

    // 4. Gallery Collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow create, update: if isApprovedUser() && isValidGalleryItem(request.resource.data);
      allow delete: if isApprovedUser();
    }

    // 5. Site Configuration Collection
    match /config/{configId} {
      allow read: if true;
      allow create, update: if isApprovedUser() && isValidSiteConfig(request.resource.data);
      allow delete: if isOwner();
    }

  }
}
